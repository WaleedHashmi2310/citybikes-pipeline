# CityBikes Pipeline Environment Variables
# Copy this file to .env and fill in your values

# --- dbt Configuration ---

# DuckDB local database path (optional, default: citybikes.duckdb)
DBT_DUCKDB_PATH=citybikes.duckdb


PROJECT_NAME = your-gcp-project-name
DBT_PROFILES_DIR = dbt/profiles
DBT_PROJECT_DIR = dbt
RAW_DATA_PATH = data/raw
TERRAFORM_DIR = terraform
NETWORKS ?= callabike-frankfurt,visa-frankfurt,callabike-koln,kvb-rad-koln,nextbike-dusseldorf,stadtrad-hamburg-db,callabike-munchen,stadtrad-stuttgart,mobibike-dresden,nextbike-leipzig,callabike-berlin,mvg-meinrad-nextbike-mainz

# Historical data generation variables
HISTORICAL_DAYS_BACK ?= 7
HISTORICAL_INTERVAL_MINUTES ?= 30
STORAGE_BACKEND ?= gcs # Options: local, gcs

# --- GCP/Terraform Credentials ---

# Path to Google Cloud service account credentials JSON file
# Required to provision GCP Resources via Terraform

GOOGLE_APPLICATION_CREDENTIALS=path/to/citybikes-terraform-sa-key.json

# BigQuery configuration (required for cloud mode)
# Will be auto-populated by scripts/generate_gcp_env.py
DBT_BIGQUERY_PROJECT=your-gcp-project-id
DBT_BIGQUERY_DATASET=citybikes
DBT_BIGQUERY_LOCATION=EU

# Will be auto-populated by scripts/create_service_account_key.py
DBT_BIGQUERY_KEYFILE=path/to/citybikes-pipeline-sa-key.json


# GCS bucket name (used by GCSStorage)
# Will be auto-populated by scripts/generate_gcp_env.py
GCS_BUCKET_NAME=your-bucket-name




# --- API Configuration ---

# CityBikes API base URL (optional override)
# CITYBIKES_API_BASE_URL=https://api.citybik.es/v2

# --- Local Development ---

# Python environment (already set by venv)
# VIRTUAL_ENV=.venv

# Note: For local development with DuckDB, only DBT_DUCKDB_PATH may be needed.
# For cloud deployment:
# 1. Use Terraform to create GCS bucket and BigQuery dataset (see terraform/README.md)
# 2. Use automation scripts to update environment variables:
#    - Run `python scripts/generate_gcp_env.py --format dotenv --update-env` to set GCS_BUCKET_NAME, DBT_BIGQUERY_DATASET, DBT_BIGQUERY_PROJECT
#    - Run `python scripts/create_service_account_key.py` to create service account key and update DBT_BIGQUERY_KEYFILE